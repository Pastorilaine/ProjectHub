{
  "name": "projecthub",
  "version": "0.3.0",
  "description": "Local-first project & task management app by IT-Veljekset Group",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "release:win": "npm run build && electron-builder --win --publish always",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@hello-pangea/dnd": "^18.0.1",
    "better-sqlite3": "^12.10.0",
    "electron-updater": "^6.2.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "electron": "^31.2.1",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.39",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.6",
    "vite": "^5.3.3"
  },
  "build": {
    "appId": "fi.it-veljekset.projecthub",
    "productName": "ProjectHub",
    "icon": "projecthub.png",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "projecthub.png",
      "!**/*.map"
    ],
    "protocols": [
      { "name": "ProjectHub", "schemes": ["projecthub"] }
    ],
    "publish": {
      "provider": "github",
      "owner": "Pastorilaine",
      "repo": "ProjectHub",
      "releaseType": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "projecthub.png",
      "publisherName": "IT-Veljekset Group"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "language": "1035"
    },
    "mac": {
      "target": "dmg",
      "icon": "projecthub.png",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": "AppImage",
      "icon": "projecthub.png",
      "category": "Office"
    }
  }
}

